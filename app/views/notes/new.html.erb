<%= content_for :head do %>
  <%= stylesheet_link_tag 'notes', 'data-turbo-track': 'reload' %>
<% end %>

<div class="full-screen-note">
  <h1>Create New Note</h1>

  <%= form_with(model: @note, url: notes_path) do |form| %>
    <div class="form-group">
      <%= form.text_field :title, placeholder: 'Title', class: 'form-input' %>
    </div>

    <div class="form-group">
      <%= form.text_area :value,
                         placeholder: 'Write your note here...',
                         class: 'form-input' %>
    </div>

    <div class="form-group color-selection">
      <label>Choose note color:</label>
      <div class="color-options">
        <%= form.radio_button :color, '#FEE9B9', checked: true, id: 'color-yellow' %>
        <label
          for="color-yellow"
          class="color-option"
          style="background-color: #FEE9B9;"
          >Yellow</label
        >

        <%= form.radio_button :color, '#B2DFC8', id: 'color-green' %>
        <label
          for="color-green"
          class="color-option"
          style="background-color: #B2DFC8;"
          >Green</label
        >

        <%= form.radio_button :color, '#B2D7EC', id: 'color-blue' %>
        <label
          for="color-blue"
          class="color-option"
          style="background-color: #B2D7EC;"
          >Blue</label
        >

        <%= form.radio_button :color, '#F3D0D6', id: 'color-pink' %>
        <label
          for="color-pink"
          class="color-option"
          style="background-color: #F3D0D6;"
          >Pink</label
        >

        <%= form.radio_button :color, '#ddd', id: 'color-gray' %>
        <label
          for="color-gray"
          class="color-option"
          style="background-color: #ddd;"
          >Gray</label
        >
      </div>
    </div>

    <%= form.hidden_field :participant_id, value: Current.user.id %>
    <%= form.hidden_field :hidden, value: false %>

    <%= form.submit 'Save', class: 'cta-button' %>
  <% end %>

  <%= link_to 'Cancel', root_path, class: 'cta' %>
</div>
