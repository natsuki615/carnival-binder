<%= form_with(model: urgent) do |form| %>
  <div class="form-group">
    <%= form.label :title, 'Title' %>
    <%= form.text_field :title, placeholder: 'Announcement title', class: 'form-input' %>
  </div>

  <div class="form-group">
    <%= form.label :value, 'Message' %>
    <%= form.text_area :value,
                       placeholder: 'Announcement details...',
                       class: 'form-input',
                       rows: 4 %>
  </div>

  <%= form.hidden_field :participant_id, value: Current.user.id %>
  <%= form.hidden_field :hidden, value: false %>

  <%= form.submit urgent.persisted? ? 'Update' : 'Post Announcement',
                  class: 'cta-button' %>
<% end %>

<%= link_to 'Cancel', urgents_path, class: 'cta' %>
